# ---------------------------------------------------------------------------
# agentrie — local dev config. Copy to `.env`. All keys validated by Zod at boot
# (src/config/env.schema.ts); the app FAILS FAST if a value is missing/invalid.
# Defaults below target the docker-compose stack and need no real AWS account.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# --- LLM ---------------------------------------------------------------------
# Leave ANTHROPIC_API_KEY empty to use the deterministic FakeLlmProvider (keyless,
# used by tests + default local runs). Set it to switch to the real AnthropicProvider.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
# Override the model context limit (tokens). For the fake provider this also bounds
# the sliding window so you can exercise summarization with small inputs.
LLM_CONTEXT_LIMIT=200000
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_MS=60000

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- MongoDB -----------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/agentrie
# TTL (days) after which ARCHIVED sessions are auto-expired by the Mongo TTL index.
SESSION_ARCHIVE_TTL_DAYS=30

# --- Agent guardrails (Phase 0) ---------------------------------------------
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOOL_CALLS=20
AGENT_TIMEOUT_MS=120000

# --- Locks (Phase 2 primitive, also used by summarizer) ----------------------
# Lock TTL must exceed worst-case agent execution time.
LOCK_TTL_MS=150000

# --- AWS / LocalStack (Phase 2) ---------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Point the SDK at LocalStack. Leave empty to use real AWS endpoints.
AWS_ENDPOINT_URL=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/agent-tasks
SQS_DLQ_URL=http://localhost:4566/000000000000/agent-tasks-dlq
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:agent-events
# SQS visibility timeout MUST exceed AGENT_TIMEOUT_MS (see events/sqs.consumer.ts).
SQS_VISIBILITY_TIMEOUT_SEC=150
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_RECEIVE_COUNT=5

# --- Observability (Phase 3) -------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=agentrie
# OTLP HTTP endpoint (Jaeger all-in-one in docker-compose exposes 4318).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Tools (Phase 4) ---------------------------------------------------------
# Filesystem tools refuse any path resolving outside this root.
TOOL_WORKSPACE_ROOT=./workspace

# --- Eval & scoring (Phase 5) ------------------------------------------------
# Bounded concurrency for running dataset cases against the AgentRunner.
EVAL_CONCURRENCY=4
# LLM-as-judge is opt-in. Keyless runs use a deterministic stub judge instead;
# set true AND an ANTHROPIC_API_KEY to grade rubric cases with the real model.
EVAL_JUDGE_ENABLED=false
# Per-scorer weights (JSON object name->weight) for the weighted-mean aggregate.
# Unlisted scorers fall back to their own defaultWeight. Example:
#   EVAL_WEIGHTS={"llm-judge":2,"exact-match":1}
EVAL_WEIGHTS={}
# Output directory for generated HTML/JSON eval reports.
EVAL_REPORT_DIR=evals/reports
